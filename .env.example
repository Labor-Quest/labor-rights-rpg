# Labor Rights RPG — Environment Variables
# Copy this file to .env and fill in values. NEVER commit .env to git.

# --- Server ---
PORT=8080
NODE_ENV=development

# --- GCP Deployment (used by deploy.sh) ---
GCP_PROJECT_ID=labor-rights-rpg

# --- Content Generation (only needed for scripts/generate.js) ---
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
